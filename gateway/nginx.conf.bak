events {
    worker_connections 1024;
}

http {
    # ── Upstream services ─────────────────────────────────────
    upstream auth_service        { server auth-service:8001; }
    upstream medical_service     { server medical-records-service:8002; }
    upstream family_service      { server family-profile-service:8003; }
    upstream ai_service          { server ai-processing-service:8004; }
    upstream notification_service { server notification-service:8005; }

    # ── Rate limiting ─────────────────────────────────────────
    limit_req_zone $binary_remote_addr zone=api:10m rate=30r/s;

    # ── LOCAL DEV: Plain HTTP on port 80 (no SSL) ─────────────
    server {
        listen 80;
        server_name localhost;

        proxy_hide_header 'Access-Control-Allow-Origin';
        proxy_hide_header 'Access-Control-Allow-Credentials';
        proxy_hide_header 'Access-Control-Allow-Methods';
        proxy_hide_header 'Access-Control-Allow-Headers';

        add_header 'Access-Control-Allow-Origin'      '$http_origin' always;
        add_header 'Access-Control-Allow-Credentials' 'true' always;
        add_header 'Access-Control-Allow-Methods'     'GET, POST, PUT, DELETE, OPTIONS' always;
        add_header 'Access-Control-Allow-Headers'     'Authorization, Content-Type' always;

        if ($request_method = OPTIONS) { return 204; }

        location = /health {
            return 200 '{"gateway":"ok","env":"local"}';
            add_header Content-Type application/json;
        }

        location /auth        { proxy_pass http://auth_service;    proxy_set_header Host $host; proxy_set_header X-Real-IP $remote_addr; }
        location /records     { proxy_pass http://medical_service; proxy_set_header Host $host; proxy_set_header X-Real-IP $remote_addr; client_max_body_size 20M; }
        location /emergency   { proxy_pass http://medical_service; proxy_set_header Host $host; proxy_set_header X-Real-IP $remote_addr; }
        location /appointments{ proxy_pass http://medical_service; proxy_set_header Host $host; proxy_set_header X-Real-IP $remote_addr; }
        location /family      { proxy_pass http://family_service;  proxy_set_header Host $host; proxy_set_header X-Real-IP $remote_addr; }
        location /health/cycle     { proxy_pass http://family_service; }
        location /health/pregnancy { proxy_pass http://family_service; }
        location /ai          { proxy_pass http://ai_service;      proxy_set_header Host $host; proxy_set_header X-Real-IP $remote_addr; proxy_read_timeout 120s; }
        location /notify      { proxy_pass http://notification_service; proxy_set_header Host $host; proxy_set_header X-Real-IP $remote_addr; }
    }
}
